{
  "name": "gfx-pkg-exporter",
  "version": "1.0.2",
  "description": "GFX PKG Exporter - After Effects render worker with Electron UI",
  "main": "electron/main.js",
  "author": "Elevation Church",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshuameza1/GFX-PKG-Exporter-Worker.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_IS_DEV=1 electron .",
    "build": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never",
    "release": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish always"
  },
  "dependencies": {
    "@nexrender/core": "^1.46.5",
    "@nexrender/action-copy": "^1.45.5",
    "aepx": "^0.0.1",
    "archiver": "^5.3.1",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.5.3",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.3.9",
    "socket.io-client": "^4.7.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "org.elevationchurch.gfx-pkg-exporter",
    "productName": "GFX PKG Exporter",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "category": "public.app-category.graphics-design",
      "identity": null
    },
    "dmg": {
      "title": "GFX PKG Exporter ${version}"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "ui/**/*"
    ],
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      },
      {
        "from": "ae/",
        "to": "ae/",
        "filter": ["**/*"]
      }
    ],
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "joshuameza1",
      "repo": "GFX-PKG-Exporter-Worker",
      "private": true,
      "releaseType": "release"
    }
  }
}
